{
  "$schema_version": "2.0",
  "id": "roleup",
  "label": "Roleup Standard Format (vF 20250928)",
  "spec_doc": "skills/_common/brands/roleup/format_spec.md",
  "slide_size": {
    "width_in": 11.693,
    "height_in": 8.268,
    "aspect": "A4-landscape"
  },
  "fonts": {
    "latin": "Yu Gothic UI",
    "ea": "Yu Gothic UI",
    "fallback_ea": ["Yu Gothic", "Hiragino Sans", "MS PGothic"]
  },
  "colors": {
    "text": "#241A17",
    "source": "#3E3A39",
    "header_bg": "#F5EFE5",
    "highlight_target": "#C78624",
    "highlight_other": "#CDCECE",
    "label_bar": "#7C4C2C",
    "label_bg": "#F2E8DD",
    "accent_revenue_bar": "#7C4C2C",
    "accent_op_margin_line": "#604C3F",
    "cagr_arrow": "#241A17",
    "subtitle": "#897141"
  },
  "chart_palette": [
    "#7C4C2C",
    "#897141",
    "#604C3F",
    "#C78624",
    "#AF7026",
    "#3E3A39",
    "#9C755F",
    "#CDCECE"
  ],
  "defaults": {
    "font_size_label_pt": 10,
    "font_size_value_pt": 10,
    "font_size_section_pt": 12,
    "font_size_chart_title_pt": 11,
    "font_size_data_label_pt": 11,
    "font_size_legend_pt": 12,
    "font_size_source_pt": 6,
    "font_size_axis_pt": 11,
    "font_size_cagr_pt": 16,

    "font_size_title_pt": 22,
    "font_size_subtitle_pt": 12,
    "font_size_key_message_pt": 14,
    "font_size_body_pt": 10,
    "font_size_executive_summary_body_pt": 12,

    "line_height_pt": 12,
    "number_format_excel": "_ * #,##0_ ;_ * (#,##0)_ ;_ \"-\"_ ;_ @_ ",
    "negative_format": "paren",
    "zero_text": "-",
    "fiscal_period_format": "YY/MM期"
  },
  "layout_rules": {
    "left_align_guide_x_in": 0.41,
    "uniform_table_width": true,
    "source_required": true,
    "subtitle_align": "left"
  },
  "executive_summary_skill_ids": ["executive-summary-pptx"],
  "placeholder_role_mapping": {
    "top_placeholder_field": "chart_title",
    "subtitle_placeholder_field": "main_message"
  }
}
